{
  "info": {
    "_postman_id": "6cb2105b-28c0-4a27-b228-f468fcdfbe4f",
    "name": "ProiectIP Backend - Demo1",
    "description": "Repo-aligned Postman collection generated from Demo1.odt. The source document covers BK2-04 through BK2-07: user profiles, volunteer profiles, ratings/reputation, and email verification. Requests intentionally match the current implementation where the ODT differs from code. Protected profile requests rely on Better Auth's signed session cookie in Postman's cookie jar after email verification/sign-in; Authorization: Bearer is not the primary auth mechanism in this repo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Email Verification",
      "description": "Better Auth routes currently implemented by src/controllers/AuthController.ts and src/auth.ts. Demo1.odt describes POST /auth/verify-email with { code }, but this repo exposes OTP verification at POST /auth/email-otp/verify-email with { email, otp }. The regular /auth/verify-email route is a token-based GET route from Better Auth.",
      "item": [
        {
          "name": "Sign Up - Email Verification User",
          "description": "Creates a fresh user and triggers email verification. A pre-request script generates a new authEmail so repeated runs do not collide. The auth hook also creates a blank profile for the new user.",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const email = `demo1${Date.now()}@example.com`;",
                  "pm.environment.set('authEmail', email);",
                  "pm.environment.unset('otp');",
                  "pm.environment.unset('authUserId');",
                  "pm.environment.unset('sessionToken');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Response contains user data', function () {",
                  "  pm.expect(json).to.have.property('user');",
                  "  pm.expect(json.user).to.have.property('email', pm.environment.get('authEmail'));",
                  "});",
                  "",
                  "if (json.user && json.user.id) {",
                  "  pm.environment.set('authUserId', json.user.id);",
                  "}",
                  "if (json.token) {",
                  "  pm.environment.set('sessionToken', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\",\n  \"name\": \"{{authName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/sign-up/email",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "sign-up", "email"]
            }
          },
          "response": []
        },
