    {
      "name": "BK2-04 User Profiles",
      "description": "Profile endpoints implemented by src/controllers/ProfileController.ts. All routes currently pass through authMiddlware, including GET /profile/:userId. Responses use sendApiResponse wrappers with data, message, status flags, app.url, and statusCode. The persisted profile data does not include name/image, even though create/update accepts those fields and writes them to the Better Auth user table.",
      "item": [
        {
          "name": "Create User Profile",
          "description": "Requires a valid Better Auth session cookie. Expected status is 201 for an authenticated user without an existing profile. If you use the Sign Up request first, the repo's auth hook may already have created a blank profile for that user.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Response uses API wrapper with profile data', function () {",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json.data).to.include.keys(['id', 'userId']);",
