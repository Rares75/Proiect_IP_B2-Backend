        {
          "name": "Verify Email OTP",
          "description": "Paste the MailDev OTP into {{otp}} before sending. On success, Better Auth returns a token and sets the signed session cookie that later profile requests use.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const otp = pm.environment.get('otp');",
                  "",
                  "if (!otp) {",
                  "  pm.test('Missing otp is rejected until MailDev code is provided', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([400, 422]);",
                  "  });",
                  "} else {",
                  "  pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "  });",
                  "",
                  "  const json = pm.response.json();",
                  "  pm.test('Email is verified and user is returned', function () {",
                  "    pm.expect(json).to.have.property('status', true);",
                  "    pm.expect(json).to.have.property('user');",
                  "  });",
                  "",
                  "  if (json.user && json.user.id) {",
                  "    pm.environment.set('authUserId', json.user.id);",
                  "  }",
                  "  if (json.token) {",
                  "    pm.environment.set('sessionToken', json.token);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/email-otp/verify-email",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "email-otp", "verify-email"]
            }
          },
          "response": []
